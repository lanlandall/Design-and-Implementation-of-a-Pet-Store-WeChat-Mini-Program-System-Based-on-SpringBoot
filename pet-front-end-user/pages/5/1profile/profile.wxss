/* pages/5/1profile/profile.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f4ff 0%, #ffffff 100%);
  padding-top: 120rpx;
}

/* 自定义导航栏 */
.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(135deg, #b39ddb, #9575cd);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(149, 117, 205, 0.3);
  z-index: 100;
}

.navbar-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.navbar-right {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.navbar-right .icon {
  font-size: 40rpx;
  color: #ffffff;
}

/* 主滚动区域 */
.main-scroll {
  height: 100%;
  background-color: transparent;
}

/* ===== 用户信息区域 ===== */
.user-section {
  background: linear-gradient(135deg, #b39ddb, #9575cd);
  margin: 30rpx;
  padding: 30rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(149, 117, 205, 0.3);
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  margin-right: 20rpx;
  background-color: #f3e5f5;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.user-phone {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.membership-code {
  background-color: rgba(255, 255, 255, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  backdrop-filter: blur(5px);
}

.code-label {
  font-size: 26rpx;
  color: #ffffff;
  margin-right: 8rpx;
}

.code-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ===== 资产统计卡片 ===== */
.assets-section {
  background-color: #ffffff;
  margin: 30rpx;
  padding: 30rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 4rpx 16rpx rgba(149, 117, 205, 0.1);
  border: 2rpx solid #ede7f6;
}

.asset-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.asset-value {
  margin-bottom: 8rpx;
}

.number {
  font-size: 36rpx;
  font-weight: 600;
  color: #5e4b8c;
}

.unit {
  font-size: 24rpx;
  color: #b39ddb;
  margin-left: 4rpx;
}

.asset-label {
  font-size: 24rpx;
  color: #9575cd;
}

.asset-divider {
  width: 2rpx;
  height: 40rpx;
  background: linear-gradient(to bottom, transparent, #d1c4e9, transparent);
}

/* ===== 菜单区域 ===== */
.menu-section {
  background-color: #ffffff;
  margin: 30rpx;
  padding: 30rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(149, 117, 205, 0.1);
  border: 2rpx solid #ede7f6;
}

.menu-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.menu-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #5e4b8c;
}

.menu-more {
  display: flex;
  align-items: center;
  color: #b39ddb;
  font-size: 26rpx;
}

.menu-more .arrow {
  font-size: 32rpx;
  margin-left: 6rpx;
}

/* 宠物列表 */
.pet-list {
  width: 100%;
  white-space: nowrap;
}

.pet-scroll {
  display: inline-flex;
  padding: 10rpx 0;
}

.pet-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
  width: 120rpx;
}

.pet-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e1d9f0, #d1c4e9);
  border: 4rpx solid #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(149, 117, 205, 0.2);
  margin-bottom: 12rpx;
}

.pet-name {
  font-size: 24rpx;
  color: #5e4b8c;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 120rpx;
}

.add-pet .add-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f3e5f5, #e1d9f0);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #9575cd;
  margin-bottom: 12rpx;
  border: 4rpx solid #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(149, 117, 205, 0.2);
}

/* 菜单网格 */
.menu-grid {
  display: flex;
  margin-bottom: 20rpx;
}

.menu-grid:last-child {
  margin-bottom: 0;
}

.menu-grid-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #f3e5f5, #e1d9f0);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #9575cd;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(149, 117, 205, 0.1);
}

.menu-label {
  font-size: 24rpx;
  color: #5e4b8c;
}

/* 列表样式 */
.list-section {
  background-color: #ffffff;
  margin: 30rpx;
  padding: 0 30rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(149, 117, 205, 0.1);
  border: 2rpx solid #ede7f6;
}

.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #f3e5f5;
}

.list-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
}

.item-icon {
  font-size: 36rpx;
  color: #9575cd;
  margin-right: 20rpx;
  width: 40rpx;
  text-align: center;
}

.item-label {
  font-size: 28rpx;
  color: #5e4b8c;
}

.item-arrow {
  font-size: 36rpx;
  color: #d1c4e9;
}

/* 底部留白 */
.bottom-space {
  height: 30rpx;
}

/* 加载状态 */
.loading-spinner {
  width: 70rpx;
  height: 70rpx;
  border: 6rpx solid #f3e5f5;
  border-top: 6rpx solid #9575cd;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}


/* 加在 profile.wxss 最后 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 998;
}
.action-sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s;
  z-index: 999;
}
.action-sheet.show {
  transform: translateY(0);
}
.action-item {
  text-align: center;
  padding: 40rpx;
  font-size: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.action-footer {
  text-align: center;
  padding: 30rpx;
  color: #666;
  font-size: 30rpx;
}


.modal-header {
  display: flex;
  justify-content: space-between;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.account-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 30rpx;
  position: relative;
}

.account-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.delete-btn {
  position: absolute;
  right: 30rpx;
  font-size: 32rpx;
  color: #ff6b6b;
}

.add-btn, .cancel-btn {
  text-align: center;
  padding: 30rpx;
  border-top: 1rpx solid #eee;
}
.add-btn { color: #9575cd; }