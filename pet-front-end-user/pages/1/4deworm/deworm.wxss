/* pages/1/4deworm/deworm.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f0ff 0%, #ebe4f5 100%);
  padding-bottom: 40rpx;
}

/* 顶部导航栏 */
.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  background: linear-gradient(135deg, #b39ddb, #9575cd);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  z-index: 100;
  padding-top: env(safe-area-inset-top);
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: white;
  font-weight: bold;
}

.navbar-title {
  font-size: 34rpx;
  font-weight: 600;
  color: white;
}

.navbar-right {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-icon {
  font-size: 36rpx;
  color: white;
}

/* 宠物选择器 */
.pet-selector {
  margin-top: 100rpx;
  margin-left: 30rpx;
  margin-right: 30rpx;
  background: white;
  border-radius: 60rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.pet-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #e1d9f0, #d1c4e9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.pet-info {
  flex: 1;
}

.pet-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #5e4b8c;
  display: block;
}

.pet-type {
  font-size: 24rpx;
  color: #b39ddb;
}

.pet-arrow {
  font-size: 28rpx;
  color: #b39ddb;
}

/* 统计卡片 */
.stats-card {
  background: white;
  margin: 24rpx 30rpx;
  border-radius: 32rpx;
  padding: 32rpx 24rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.stats-item {
  text-align: center;
  flex: 1;
}

.stats-number {
  font-size: 44rpx;
  font-weight: 700;
  color: #9575cd;
  display: block;
}

.stats-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.stats-divider {
  width: 1rpx;
  background: #ede7f6;
}

/* 记录列表头部 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #5e4b8c;
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #b39ddb, #9575cd);
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  color: white;
  font-size: 26rpx;
}

.add-icon {
  font-size: 28rpx;
  font-weight: bold;
}

/* 记录列表 */
.record-list {
  height: calc(100vh - 400rpx);
  padding: 0 30rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #b39ddb;
}

/* 记录卡片 */
.record-card {
  background: white;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #ede7f6;
}

.record-type {
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.type-in {
  background: #e8f5e9;
  color: #2e7d32;
}

.type-out {
  background: #e3f2fd;
  color: #1565c0;
}

.record-date {
  font-size: 26rpx;
  color: #999;
}

.record-actions {
  display: flex;
  gap: 16rpx;
}

.edit-btn, .delete-btn {
  font-size: 28rpx;
  padding: 4rpx 8rpx;
}

.record-body {
  padding: 16rpx 0;
}

.record-row {
  display: flex;
  margin-bottom: 12rpx;
}

.row-label {
  width: 140rpx;
  font-size: 26rpx;
  color: #999;
}

.row-value {
  flex: 1;
  font-size: 26rpx;
  color: #4a4a5a;
}

.record-footer {
  padding-top: 12rpx;
  border-top: 1rpx solid #f0eaf8;
}

.days-badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: #e8f5e9;
  border-radius: 30rpx;
  font-size: 22rpx;
  color: #2e7d32;
}

.days-badge.overdue {
  background: #ffebee;
  color: #c62828;
}

.days-badge.today {
  background: #fff3e0;
  color: #ef6c00;
}

.bottom-tip {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #ccc;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.modal-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 201;
  max-height: 80vh;
}

.modal-container.show {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #ede7f6;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #5e4b8c;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx 40rpx;
  border-top: 1rpx solid #ede7f6;
}

.modal-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  border: none;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #b39ddb, #9575cd);
  color: white;
}

/* 表单样式 */
.form-group {
  margin-bottom: 30rpx;
}

.form-group label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #5e4b8c;
  margin-bottom: 12rpx;
}

.type-switch {
  display: flex;
  gap: 20rpx;
}

.type-option {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 48rpx;
  font-size: 28rpx;
  color: #666;
}

.type-option.active {
  background: linear-gradient(135deg, #b39ddb, #9575cd);
  color: white;
}

.form-picker {
  padding: 20rpx;
  background: #f8f4ff;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #4a4a5a;
}

.form-input {
  padding: 20rpx;
  background: #f8f4ff;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: none;
  width: 100%;
}

.form-textarea {
  padding: 20rpx;
  background: #f8f4ff;
  border-radius: 16rpx;
  font-size: 28rpx;
  width: 100%;
  min-height: 150rpx;
}