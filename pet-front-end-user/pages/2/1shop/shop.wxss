/* pages/2/1shop/shop.wxss */
.page {
  min-height: 100vh;
  background-color: #f8f4ff;
  padding-top: 120rpx;
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 自定义导航栏 - 淡紫色渐变 */
.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(135deg, #b39ddb, #9575cd);
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(149, 117, 205, 0.3);
  z-index: 100;
}

.pet-switch {
  display: flex;
  background-color: rgba(255, 255, 255, 0.25);
  border-radius: 60rpx;
  padding: 6rpx;
  width: 220rpx;
  flex-shrink: 0;
  backdrop-filter: blur(10px);
}

.switch-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  line-height: 60rpx;
  border-radius: 60rpx;
  color: rgba(255, 255, 255, 0.9);
  transition: all 0.3s;
}

.switch-item.active {
  background-color: #ffffff;
  color: #9575cd;
  font-weight: 500;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

/* 搜索框 - 可输入 */
.search-box {
  flex: 1;
  height: 70rpx;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  margin: 0 20rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 28rpx;
  color: #b39ddb;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 26rpx;
  color: #5e4b8c;
  background: transparent;
  border: none;
}

.search-input::placeholder {
  color: #c5b0e0;
  font-size: 24rpx;
}

.clear-btn {
  font-size: 28rpx;
  color: #b39ddb;
  padding: 0 8rpx;
}

.navbar-placeholder {
  width: 20rpx;
  flex-shrink: 0;
}


/* 悬浮按钮 */
.publish-btn {
  position: fixed;
  right: 40rpx;
  bottom: 100rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #b39ddb, #9575cd);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(149, 117, 205, 0.3);
  z-index: 90;
}

.publish-icon {
  font-size: 48rpx;
  color: #ffffff;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  color: #b39ddb;
  font-size: 28rpx;
}

.loading-spinner {
  width: 70rpx;
  height: 70rpx;
  border: 6rpx solid #f3e5f5;
  border-top: 6rpx solid #9575cd;
  border-radius: 50%;
  margin-bottom: 20rpx;
  animation: spin 1s linear infinite;
}

.loading-spinner.small {
  width: 40rpx;
  height: 40rpx;
  border-width: 4rpx;
  margin-right: 16rpx;
  margin-bottom: 0;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 分类栏 */
.category-bar {
  background-color: #ffffff;
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  position: sticky;
  top: 120rpx;
  z-index: 90;
  box-shadow: 0 2rpx 10rpx rgba(149, 117, 205, 0.1);
  border-bottom: 2rpx solid #ede7f6;
  flex-shrink: 0;
}

.category-fixed {
  flex-shrink: 0;
  width: 120rpx;
  text-align: center;
  font-size: 28rpx;
  color: #5e4b8c;
  font-weight: 500;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.category-fixed.active-fixed {
  color: #9575cd;
}

.category-fixed.left::after {
  content: '';
  position: absolute;
  right: 0;
  top: 20%;
  height: 60%;
  width: 2rpx;
  background: linear-gradient(to bottom, transparent, #d1c4e9, transparent);
}

.arrow {
  font-size: 32rpx;
  margin-left: 6rpx;
  color: #b39ddb;
}

.category-scroll {
  flex: 1;
  white-space: nowrap;
  overflow-x: auto;
  overflow-y: hidden;
}

.scroll-inner {
  display: inline-flex;
  padding: 0 20rpx;
}

.category-item {
  display: inline-block;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #b39ddb;
  line-height: 60rpx;
  margin: 0 10rpx;
  border-radius: 30rpx;
  transition: all 0.2s;
  background-color: #f3e5f5;
  white-space: nowrap;
}

.category-item.active-category {
  background: linear-gradient(135deg, #b39ddb, #9575cd);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(149, 117, 205, 0.3);
}

/* 下拉菜单 */
.dropdown-menu {
  position: fixed;
  top: 206rpx;
  left: 0;
  right: 0;
  background: white;
  z-index: 89;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.1);
  max-height: 400rpx;
  overflow-y: auto;
  border-radius: 0 0 20rpx 20rpx;
}

.dropdown-item {
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: #666;
  border-bottom: 1rpx solid #f0f0f0;
}

.dropdown-item.active {
  color: #9575cd;
  background-color: #f3e5f5;
  font-weight: 500;
}

/* 商品容器 */
.goods-container {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
  background-color: #f8f4ff;
}

/* 商品网格 */
.goods-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.goods-item {
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(149, 117, 205, 0.1);
  transition: transform 0.2s, box-shadow 0.2s;
  border: 2rpx solid #ede7f6;
  display: flex;
  flex-direction: column;
}

.goods-item:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(149, 117, 205, 0.2);
}

.goods-image {
  width: 100%;
  height: 280rpx;
  background: linear-gradient(135deg, #e1d9f0, #d1c4e9);
  flex-shrink: 0;
}

.goods-info {
  padding: 20rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.goods-name {
  font-size: 28rpx;
  color: #5e4b8c;
  font-weight: 500;
  line-height: 1.4;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 76rpx;
}

.goods-price-wrap {
  margin-bottom: 16rpx;
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
}

.goods-price {
  font-size: 32rpx;
  color: #9575cd;
  font-weight: 600;
  margin-right: 12rpx;
}

.goods-original-price {
  font-size: 24rpx;
  color: #b39ddb;
  text-decoration: line-through;
}

.goods-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.goods-sales {
  font-size: 22rpx;
  color: #b39ddb;
}

.add-cart-btn {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #b39ddb, #9575cd);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(149, 117, 205, 0.3);
}

.cart-icon {
  font-size: 40rpx;
  color: #ffffff;
  line-height: 1;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
  color: #b39ddb;
  font-size: 28rpx;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

/* 加载更多 & 没有更多 */
.load-more, .no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  color: #b39ddb;
  font-size: 24rpx;
}

.load-more .loading-spinner {
  margin-right: 16rpx;
  margin-bottom: 0;
}

/* ========== 弹窗样式 - 使用绝对定位确保垂直上下居中 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.modal-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 85%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  z-index: 1001;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.2);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  flex-shrink: 0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #5e4b8c;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
  max-height: 50vh;
  overflow-y: auto;
  flex: 1;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
  border-top: 1rpx solid #eee;
  flex-shrink: 0;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: #9575cd;
  color: #fff;
}

.product-info-card {
  display: flex;
  gap: 20rpx;
  padding-bottom: 30rpx;
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.product-info-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
}

.product-info-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #5e4b8c;
}

.product-info-price {
  font-size: 36rpx;
  color: #9575cd;
  font-weight: bold;
  margin-top: 8rpx;
}

.form-item {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.form-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #666;
}

.form-input {
  flex: 1;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.quantity-btn {
  width: 60rpx;
  height: 60rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #9575cd;
}

.quantity-num {
  font-size: 34rpx;
  min-width: 60rpx;
  text-align: center;
  font-weight: 500;
}

.total-section {
  display: flex;
  justify-content: flex-end;
  align-items: baseline;
  padding-top: 30rpx;
  margin-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.total-label {
  font-size: 30rpx;
  color: #666;
}

.total-price {
  font-size: 44rpx;
  font-weight: bold;
  color: #9575cd;
  margin-left: 10rpx;
}

/* 大屏幕适配 */
@media (min-width: 768px) {
  .modal-container {
    width: 70%;
    max-width: 500px;
  }
}


/* 地址选择 */
.address-selector {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 10rpx;
}

.address-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #666;
}

.address-info {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.address-detail {
  font-size: 28rpx;
  color: #333;
}

.address-arrow {
  font-size: 40rpx;
  color: #999;
}

.address-contact {
  padding-left: 140rpx;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  color: #666;
}

/* 地址项 - 居中 */
.address-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  text-align: center;
  position: relative;
}

.address-item.active {
  background: #f8f4ff;
}

.address-name {
  font-size: 30rpx;
  font-weight: 500;
}

.address-phone {
  font-size: 26rpx;
  color: #666;
  margin-left: 20rpx;
}

.address-item .address-detail {
  display: block;
  margin-top: 10rpx;
}

.address-delete {
  position: absolute;
  right: 80rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
}

.address-check {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #9575cd;
  font-size: 36rpx;
}

/* 表单输入 - 居中 */
.form-input {
  width: 100%;
  height: 90rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  text-align: center;
}