/** app.wxss - 全局样式 **/

/* 全局背景色 */
page {
  background-color: #f8f4ff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  color: #5e4b8c;
}

/* 淡紫色主题色变量 */
:root {
  --primary-light: #b39ddb;
  --primary: #9575cd;
  --primary-dark: #7e57c2;
  --primary-soft: #e1d9f0;
  --primary-bg: #f8f4ff;
  --primary-border: #ede7f6;
  --text-primary: #5e4b8c;
  --text-secondary: #b39ddb;
  --text-light: #d1c4e9;
}

/* tabBar 图标变透明 */
.tab-bar-icon {
  opacity: 0.1;
}

/* 通用卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(149, 117, 205, 0.1);
  border: 2rpx solid #ede7f6;
}

/* 通用按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #b39ddb, #9575cd);
  color: #ffffff;
  border-radius: 60rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(149, 117, 205, 0.3);
}

.btn-primary:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-secondary {
  background-color: #f3e5f5;
  color: #9575cd;
  border-radius: 60rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-secondary:active {
  background-color: #e1d9f0;
}

/* 通用标题样式 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #5e4b8c;
  margin-bottom: 20rpx;
  padding-left: 30rpx;
  position: relative;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(135deg, #b39ddb, #9575cd);
  border-radius: 4rpx;
}

/* 通用分割线 */
.divider {
  height: 2rpx;
  background: linear-gradient(to right, transparent, #d1c4e9, transparent);
  margin: 30rpx 0;
}

/* 加载动画 */
@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-spinner {
  width: 70rpx;
  height: 70rpx;
  border: 6rpx solid #f3e5f5;
  border-top: 6rpx solid #9575cd;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

/* 空状态样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #b39ddb;
  font-size: 28rpx;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

/* 自定义导航栏样式（用于各页面） */
.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(135deg, #b39ddb, #9575cd);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(149, 117, 205, 0.3);
  z-index: 100;
  color: #ffffff;
}

.navbar-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.navbar-back {
  font-size: 48rpx;
  color: #ffffff;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.navbar-right {
  font-size: 40rpx;
  color: #ffffff;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}